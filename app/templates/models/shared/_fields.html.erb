      Description
      <%= scope(:popover_trigger_button, tip: :info, target: :description).render %>
    </label>

    <%= form.text_field :description,
                        id: :model_description,
                        value: field_for(:description, fields, model),
                        class: :value,
                        autocomplete: :off %>
  <% end %>

