<% current_screen = device.current_screen %>

<%= render "shared/title", text: "#{device.label} Device" %>

<section class="bit-page page-devices">
  <header class="bit-header">
    <ul class="bit-breadcrumbs">
      <li class="bit-breadcrumb"><%= link_to "Devices", routes.path(:devices), class: :link %></li>
      <li class="bit-breadcrumb"><%= device.label %></li>
    </ul>
  </header>

  <div class="bit-body">
    <div class="bit-card device">
      <h2 class="label"><%= device.label %></h2>

      <%= render "shared/popovers/triggers/screen", name: "screen-#{current_screen.id}" do %>
        <%= render "shared/screen", uri: current_screen.image_uri %>
      <% end %>

      <%= scope(:popover_screen_content, **current_screen.popover_attributes).render %>
      <%= render "measurements", device: %>

      <div class="actions">
        <%= render "shared/actions/edit", path: routes.path(:device_edit, id: device.id) %>
        <%= render "shared/actions/logs", path: routes.path(:device_logs, device_id: device.id) %>
      </div>

      <%= scope(:tooltip_action_content, label: "Edit").render %>
      <%= scope(:tooltip_action_content, label: "Logs").render %>

      <dl class="bit-definition-list">
        <dt class="key">
          Model
          <%= scope(:popover_trigger_button, tip: :info, target: :model).render %>
        </dt>
        <dd class="value">
          <%= link_to device.model.label, routes.path(:model, id: device.model_id) %>
        </dd>

        <dt class="key">
          Playlist
          <%= scope(:popover_trigger_button, tip: :info, target: :playlist).render %>
        </dt>
        <dd class="value">
          <%= device.playlist ? link_to(device.playlist.label, routes.path(:playlist, id: device.playlist_id)) : nil %>
        </dd>

        <dt class="key">
          MAC Address
          <%= scope(:popover_trigger_button, tip: :info, target: :mac_address).render %>
        </dt>
        <dd class="value bit-secret"><%= device.mac_address %></dd>

        <dt class="key">
           API Key
           <%= scope(:popover_trigger_button, tip: :info, target: :api_key).render %>
         </dt>
         <dd class="value bit-secret"><%= device.api_key %></dd>

        <dt class="key">
          Refresh Rate
          <%= scope(:popover_trigger_button, tip: :info, target: :refresh_rate).render %>
        </dt>
        <dd class="value"><%= device.refresh_rate %></dd>

        <dt class="key">
          Image Timeout
          <%= scope(:popover_trigger_button, tip: :info, target: :image_timeout).render %>
        </dt>
        <dd class="value"><%= device.image_timeout %></dd>

        <dt class="key">
          Image Cached
          <%= scope(:popover_trigger_button, tip: :info, target: :image_cached).render %>
        </dt>
        <dd class="value"><%= boolean device.image_cached %></dd>

        <dt class="key">Dimensions</dt>
        <dd class="value"><%= device.dimensions %></dd>

        <dt class="key"><%= link_to "Firmware", routes.path(:firmwares)%></dt>
        <dd class="value"><%= device.firmware_version %></dd>

        <dt class="key">
          Firmware Update
          <%= scope(:popover_trigger_button, tip: :info, target: :firmware_update).render %>
        </dt>
        <dd class="value"><%= boolean device.firmware_update %></dd>

        <dt class="key">
          Firmware Profile
          <%= scope(:popover_trigger_button, tip: :info, target: :firmware_profile).render %>
        </dt>
        <dd class="value"><%= boolean device.firmware_profile %></dd>

        <dt class="key">
          Display Compatibility
          <%= scope(:popover_trigger_button, tip: :info, target: :display_compatibility).render %>
        </dt>
        <dd class="value"><%= boolean device.display_compatibility %></dd>

        <dt class="key">
          Display Profile
          <%= scope(:popover_trigger_button, tip: :info, target: :display_profile).render %>
        </dt>
        <dd class="value"><%= device.formatted_display_profile %></dd>

        <dt class="key">
          Touch Bar
          <%= scope(:popover_trigger_button, tip: :info, target: :touch_bar).render %>
        </dt>
        <dd class="value"><%= device.formatted_touch_bar %></dd>

        <dt class="key">
          Wake Reason
          <%= scope(:popover_trigger_button, tip: :info, target: :wake_reason).render %>
        </dt>
        <dd class="value"><%= device.wake_description %></dd>

        <dt class="key">
          Wake Duration
          <%= scope(:popover_trigger_button, tip: :info, target: :wake_duration).render %>
        </dt>
        <dd class="value"><%= device.wake_duration %> seconds</dd>

        <dt class="key">
          Sleep Start
          <%= scope(:popover_trigger_button, tip: :info, target: :sleep_start).render %>
        </dt>
        <dd class="value"><%= human_time device.sleep_start_at %></dd>

        <dt class="key">
          Sleep Stop
          <%= scope(:popover_trigger_button, tip: :info, target: :sleep_stop).render %>
        </dt>
        <dd class="value"><%= human_time device.sleep_stop_at %></dd>

        <dt class="key">Created</dt>
        <dd class="value"><%= human_at device.created_at %></dd>

        <dt class="key">Updated</dt>
        <dd class="value"><%= human_at device.updated_at %></dd>

        <dt class="key">
          Synchronized
          <%= scope(:popover_trigger_button, tip: :info, target: :synced_at).render %>
        </dt>
        <dd class="value"><%= human_at device.synced_at %></dd>
      </dl>
    </div>
  </div>

  <%= scope(:tooltip_action_content, label: "Info").render %>
  <%= render "devices/shared/popovers/all" %>
</section>
