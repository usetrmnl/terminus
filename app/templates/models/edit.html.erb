<%= render "shared/title", text: "Edit #{model.label} Model" %>

<section class="bit-page page-models">
  <header class="bit-header">
    <ul class="bit-breadcrumbs">
      <li class="bit-breadcrumb"><%= link_to "Models", routes.path(:models), class: :link %></li>

      <li class="bit-breadcrumb">
        <%= link_to model.label, routes.path(:model, id: model.id), class: :link %>
      </li>

      <li class="bit-breadcrumb">Edit</li>
    </ul>
  </header>

  <div class="bit-body">
    <div class="models">
      <%= form_for :model,
                   routes.path(:model, id: model.id),
                   method: :put,
                   class: "bit-card bit-form model" do |form| %>
        <h1 class="label">Edit Model</h1>

        <%= render "models/shared/fields",
                   form:,
                   model:,
                   palette_options:,
                   fields:,
                   errors: %>

        <div class="form-actions">
          <%= render "shared/actions/save",
                     form:,
                     verb: :put,
                     path: routes.path(:model, id: model.id) %>

          <%= link_to "Cancel",
                      routes.path(:model, id: model.id),
                      class: "bit-button-decline",
                      **HTMX[
                        get: routes.path(:model, id: model.id),
                        trigger: :click,
                        target: "closest .bit-page",
                        push_url: true
                      ] %>
        </div>
      <% end %>
    </div>
  </div>
</section>
