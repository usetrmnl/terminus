<%= render "shared/title", text: "Mirror #{playlist.label} Playlist" %>

<section class="bit-page page-playlists">
  <header class="bit-header">
    <ul class="bit-breadcrumbs">
      <li class="bit-breadcrumb">
        <%= link_to "Playlists", routes.path(:playlists), class: :link %>
      </li>

      <li class="bit-breadcrumb">
        <%= link_to playlist.label, routes.path(:playlist, id: playlist.id), class: :link %>
      </li>

      <li class="bit-breadcrumb">Mirror</li>
    </ul>
  </header>

  <div class="bit-body">
    <div class="playlists">
      <%= form_for :mirror,
                   routes.path(:playlist_mirror, playlist_id: playlist.id),
                   method: :put,
                   class: "bit-card bit-form playlist" do |form| %>
        <%= tag.input name: :_csrf_token, type: :hidden, value: csrf_token %>

        <h1 class="label">Mirror <%= playlist.label %></h1>

        <p class="description">
          Check (or uncheck) the devices you'd like this playlist mirrored too.
        </p>

        <fieldset class="column">
          <% devices.each do |device| %>
            <%= render :fields, form:, playlist_id: playlist.id, device: %>
          <% end %>
        </fieldset>

        <div class="form-actions">
          <%= render "shared/actions/save",
                     form:,
                     verb: :put,
                     path: routes.path(:playlist_mirror, playlist_id: playlist.id) %>

          <%= link_to "Cancel",
                      routes.path(:playlist, id: playlist.id),
                      class: "bit-button-decline" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
