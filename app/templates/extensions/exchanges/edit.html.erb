<%= render "shared/title", text: "Edit Exchange" %>

<section class="bit-page">
  <header class="bit-header">
    <ul class="bit-breadcrumbs">
      <li class="bit-breadcrumb">
        <%= link_to "Extensions", routes.path(:extensions), class: :link %>
      </li>

      <li class="bit-breadcrumb">
        <%= link_to extension.label, routes.path(:extension_edit, id: extension.id), class: :link %>
      </li>

      <li class="bit-breadcrumb">
        <%= link_to "Exchanges",
                    routes.path(:extension_exchanges, extension_id: extension.id),
                    class: :link %>
      </li>

      <li class="bit-breadcrumb">Edit</li>
    </ul>
  </header>

  <div class="bit-body">
    <%= form_for :exchange,
                 routes.path(:extension_exchange, extension_id: extension.id, id: exchange.id),
                 method: :put,
                 class: "bit-card bit-form" do |form| %>

      <h1 class="label">Edit Exchange</h1>
      <%= exchange.status %>

      <%= render "extensions/exchanges/shared/fields",
                 form:,
                 exchange:,
                 fields:,
                 errors: %>

      <div class="form-actions">
        <%= form.submit "Save", class: "bit-button-accept" %>

        <%= link_to "Cancel",
                    routes.path(:extension_exchanges, extension_id: extension.id),
                    class: "bit-button-decline" %>
      </div>
    <% end %>
  </div>

  <%= scope(:tooltip_action_content, label: "Info").render %>
</section>
