<li id="<%= item.id %>" class="bit-card">
  <h2 class="label"><%= item.name %></h2>

  <%= scope(
        :popover_trigger_button,
        target: "screen-#{item.id}"
      ).render("shared/popovers/triggers/screen") do %>
    <%= render "shared/screen", uri: item.screenshot_url %>
  <% end %>

  <%= scope(
        :popover_screen_content,
        id: item.id,
        label: item.name,
        uri: item.screenshot_url
      ).render %>

  <div class="info">
    <span><%= pluralize "connection", "s", item.statistics.installs %></span>
    <span><%= pluralize "fork", "s", item.statistics.forks %></span>
  </div>

  <div class="actions">
    <%= form_for routes.path(:extensions_gallery) do |form| %>
      <%= form.hidden_field :id, value: item.id %>

      <%= form.submit class: "action bit-button bit-tooltip-trigger",
                      interestfor: "tooltip-action-import" do %>
        <%= image_tag "icons/plus.svg", alt: "Import", class: :icon, width: 25, height: 25 %>
      <% end %>
    <% end %>

    <%= render "shared/actions/download",
               path: "https://trmnl.com/api/plugin_settings/#{item.id}/archive",
               name: "#{item.name}.zip" %>
  </div>
</li>
