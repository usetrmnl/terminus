<%= render "shared/title", text: "New Extension" %>

<section class="bit-page page-extensions">
  <header class="bit-header">
    <ul class="bit-breadcrumbs">
      <li class="bit-breadcrumb">
        <%= link_to "Extensions", routes.path(:extensions), class: :link %>
      </li>

      <li class="bit-breadcrumb">New</li>
    </ul>
  </header>

  <div class="bit-body">
    <div class="extensions">
      <%= form_for :extension,
                   routes.path(:extensions),
                   class: "bit-card bit-form extension" do |form| %>

        <h1 class="label">New Extension</h1>

        <%= render "extensions/shared/fields",
                   form:,
                   models:,
                   devices:,
                   extension:,
                   fields:,
                   errors: %>

        <div class="form-actions">
         <%= render "shared/actions/save", form:, path: routes.path(:extensions) %>
         <%= link_to "Cancel", routes.path(:extensions), class: "bit-button-decline" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
