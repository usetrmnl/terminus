<fieldset class="row">
  <fieldset class="column">
    <fieldset class="column"
              x-data="{
                kind: '<%= field_for :kind, fields, extension %>',
                homeAssistantSourceMode: '<%= field_for :home_assistant_source_mode, fields, extension %>',
                verb: '<%= field_for :verb, fields, extension %>'
              }">

      <legend class="legend">Settings</legend>

      <%= scope(:form_field, key: :label, errors:).render do %>
        <label class="key" for="extension_label">
          Label
          <%= render "shared/popovers/triggers/default", name: :label %>
        </label>

        <%= form.text_field :label,
                            id: :extension_label,
                            value: field_for(:label, fields, extension),
                            class: :value,
                            autocomplete: :off %>
      <% end %>

      <%= scope(:form_field, key: :name, errors:).render do %>
        <label class="key" for="extension_name">
          Name
          <%= render "shared/popovers/triggers/default", name: :name %>
        </label>

        <%= form.text_field :name,
                            id: :extension_name,
                            value: field_for(:name, fields, extension),
                            class: :value,
                            autocomplete: :off %>
      <% end %>

      <%= scope(:form_field, key: :description, errors:).render do %>
        <label class="key" for="extension_description">
          Description
          <%= render "shared/popovers/triggers/default", name: :description %>
        </label>

        <%= form.text_field :description,
                            id: :extension_description,
                            value: field_for(:description, fields, extension),
                            class: :value,
                            autocomplete: :off %>
      <% end %>

      <%= scope(
            :form_field,
            key: :tags,
            errors:,
            alpine: {data: "{tags: #{extension ? extension.alpine_tags : []}, nascence: '', index: 0}"}
          ).render do %>

        <%= form.hidden_field :tags, id: :extension_tags, "x-bind:value" => "tags.join(' ')" %>

        <label class="key" for="tag">
          Tags
          <%= render "shared/popovers/triggers/default", name: :tags %>
        </label>

        <%= tag.input id: :tag,
                      name: :tag,
                      class: :value,
                      placeholder: "Type your tag and hit enter to create.",
                      "x-model" => "nascence",
                      "x-on:keydown.enter.prevent" => "if (nascence.trim() !== '') { tags.push(nascence.trim()); nascence = '';}" %>

        <div class="bit-pills">
          <template x-for="(tag, index) in tags" x-bind="index">
            <button type="button"
                    class="bit-pill bit-pill-active"
                    x-text="tag"
                    x-on:click="tags.splice(index, 1)">
            </button>
          </template>
        </div>
      <% end %>

      <%= scope(:form_field, key: :mode, errors:).render do %>
        <label class="key" for="extension_unit">
          Mode
          <%= render "shared/popovers/triggers/default", name: :mode %>
        </label>

        <% options = [["Text", "text"], ["Art", "dither"]] %>
        <%= form.select :mode, options, id: :extension_mode, class: :value %>
      <% end %>

      <div class="bit-toggle-field">
        <h2 class="bit-toggle-label">Kind</h2>

        <%= render "shared/radios/bar",
                   items: [
                     ['Home Assistant', 'home_assistant'],
                     %w[Image image],
                     %w[Poll poll],
                     %w[Static static]
                   ],
                   name: "extension[kind]",
                   model: "kind" %>

        <p class="help" x-show="kind === 'home_assistant'">
          Render Home Assistant REST API data.
        </p>

        <p class="help" x-show="kind === 'image'">
          Render remote images.
        </p>

        <p class="help" x-show="kind === 'poll'">
          Render remote data.
        </p>

        <p class="help" x-show="kind === 'static'">
          Render local data. Use the body field, below, to supply JSON data.
        </p>
      </div>

      <div x-show="kind === 'image' || kind === 'poll'">
        <% if request.path.end_with?("new") || request.post? %>
          <p>💡 You'll be able to manage exchanges after this extension is created.</p>
        <% else %>
          <%= link_to "Exchanges",
                      routes.path(:extension_exchanges, extension_id: extension.id),
                      "x-show" => "kind === 'image' || kind === 'poll'" %>

          <ul>
            <% exchanges.each do |exchange| %>
              <%= render :request, exchange:, extension: %>
            <% end %>
          </ul>
        <% end %>
      </div>

      <div x-show="kind === 'home_assistant'"
           x-data="{
             openEntityPicker: false,
             entityQuery: '',
             entityResults: [],
             selectedEntityDetails: [],
             entityError: '',
             entityLoading: false,
             entityDetailsLoading: false,
             entityDetailsError: '',
             entityIds() {
               const textarea = this.$refs.homeAssistantEntityIds;
               if (!textarea) return [];
               return textarea.value.split('\n').map((line) => line.trim()).filter((line) => line.length > 0);
             },
             setEntityIds(ids) {
               const textarea = this.$refs.homeAssistantEntityIds;
               if (!textarea) return;
               textarea.value = ids.join('\n');
               textarea.dispatchEvent(new Event('input', { bubbles: true }));
             },
             parseAttributeMap() {
               const textarea = this.$refs.homeAssistantAttributeMap;
               if (!textarea) return {};
               const value = textarea.value.trim();
               if (!value) return {};
               try {
                 const parsed = JSON.parse(value);
                 return parsed && typeof parsed === 'object' ? parsed : {};
               } catch (_error) {
                 return {};
               }
             },
             writeAttributeMap(map) {
               const textarea = this.$refs.homeAssistantAttributeMap;
               if (!textarea) return;
               textarea.value = JSON.stringify(map, null, 2);
               textarea.dispatchEvent(new Event('input', { bubbles: true }));
             },
             aliasMap() {
               const map = this.parseAttributeMap();
               const aliases = map.aliases;
               return aliases && typeof aliases === 'object' ? aliases : {};
             },
             normalizeAlias(value) {
               return String(value || '')
                 .toLowerCase()
                 .replace(/[^a-z0-9_]+/g, '_')
                 .replace(/^_+|_+$/g, '') || 'entity';
             },
             recommendedAlias(entityId) {
               const raw = String(entityId || '').split('.')[1] || String(entityId || '');
               const base = this.normalizeAlias(raw);
               const aliases = this.aliasMap();
               const used = new Set(Object.keys(aliases));
               if (!used.has(base)) return base;
               let idx = 2;
               while (used.has(base + '_' + idx)) idx += 1;
               return base + '_' + idx;
             },
             setAlias(entityId, aliasName) {
               const map = this.parseAttributeMap();
               const aliases = map.aliases && typeof map.aliases === 'object' ? map.aliases : {};
               aliases[aliasName] = entityId;
               map.aliases = aliases;
               this.writeAttributeMap(map);
             },
             aliasFor(entityId) {
               const aliases = this.aliasMap();
               return Object.keys(aliases).find((name) => aliases[name] === entityId) || this.recommendedAlias(entityId);
             },
             addEntity(entity) {
               const current = this.entityIds();
               if (!current.includes(entity.entity_id)) current.push(entity.entity_id);
               this.setEntityIds(current);
               this.setAlias(entity.entity_id, this.aliasFor(entity.entity_id));
               this.loadSelectedEntityDetails();
             },
             searchEntities() {
               this.entityLoading = true;
               this.entityError = '';
               const query = encodeURIComponent(this.entityQuery || '');
               fetch('/home-assistant/entities?query=' + query, { headers: { 'Accept': 'application/json' } })
                 .then((response) => response.json().then((body) => ({ ok: response.ok, body })))
                 .then(({ ok, body }) => {
                   if (!ok) {
                     this.entityResults = [];
                     this.entityError = body.error || 'Unable to load Home Assistant entities.';
                     return;
                   }
                   this.entityResults = body.data || [];
                 })
                 .catch(() => {
                   this.entityResults = [];
                   this.entityError = 'Unable to load Home Assistant entities.';
                 })
                 .finally(() => { this.entityLoading = false; });
             },
             loadSelectedEntityDetails() {
               const ids = this.entityIds();
               if (!ids.length) {
                 this.selectedEntityDetails = [];
                 this.entityDetailsError = '';
                 return;
               }
               this.entityDetailsLoading = true;
               this.entityDetailsError = '';
               const query = encodeURIComponent(ids.join(','));
               fetch('/home-assistant/entities?entity_ids=' + query, { headers: { 'Accept': 'application/json' } })
                 .then((response) => response.json().then((body) => ({ ok: response.ok, body })))
                 .then(({ ok, body }) => {
                   if (!ok) {
                     this.selectedEntityDetails = [];
                     this.entityDetailsError = body.error || 'Unable to load selected entity details.';
                     return;
                   }
                   this.selectedEntityDetails = body.data || [];
                 })
                 .catch(() => {
                   this.selectedEntityDetails = [];
                   this.entityDetailsError = 'Unable to load selected entity details.';
                 })
                 .finally(() => { this.entityDetailsLoading = false; });
             }
           }"
           x-init="loadSelectedEntityDetails()">
        <p>
          Configure your host connection via
          <%= link_to "Home Assistant Settings", routes.path(:settings_home_assistant), class: :link %>.
        </p>

        <%= scope(:form_field, key: :home_assistant_source_mode, errors:).render do %>
          <label class="key" for="extension_home_assistant_source_mode">Source Mode</label>
          <%= form.select :home_assistant_source_mode,
                          [["Entity", "entity"], ["Endpoint", "endpoint"]],
                          id: :extension_home_assistant_source_mode,
                          class: :value,
                          "x-model" => "homeAssistantSourceMode" %>
        <% end %>

        <%= scope(
              :form_field,
              key: :home_assistant_entity_ids,
              errors:,
              alpine: {show: "homeAssistantSourceMode === 'entity'"}
            ).render do %>
          <% raw_entity_ids = field_for(:home_assistant_entity_ids, fields, extension) %>
          <% entity_ids_value = raw_entity_ids.is_a?(Array) ? raw_entity_ids.join("\n") : raw_entity_ids %>
          <label class="key" for="extension_home_assistant_entity_ids">Entity IDs</label>
          <div style="display:flex; justify-content:flex-end; margin-bottom:8px;">
            <button type="button"
                    class="bit-button-accept"
                    x-on:click="openEntityPicker = true; searchEntities()">
              Browse Entities
            </button>
          </div>
          <%= form.text_area :home_assistant_entity_ids,
                             entity_ids_value,
                             id: :extension_home_assistant_entity_ids,
                             class: :value,
                             autocomplete: :off,
                              placeholder: "media_player.sonos_roam\nweather.home",
                             "x-ref" => "homeAssistantEntityIds",
                             "x-on:input.debounce.250ms" => "loadSelectedEntityDetails()" %>
          <p class="help">One entity ID per line. Use Browse Entities for search and quick add.</p>
        <% end %>

        <%= scope(
              :form_field,
              key: :home_assistant_endpoint_path,
              errors:,
              alpine: {show: "homeAssistantSourceMode === 'endpoint'"}
            ).render do %>
          <label class="key" for="extension_home_assistant_endpoint_path">Endpoint Path</label>
          <%= form.text_field :home_assistant_endpoint_path,
                              id: :extension_home_assistant_endpoint_path,
                              value: field_for(:home_assistant_endpoint_path, fields, extension),
                              class: :value,
                              autocomplete: :off %>
        <% end %>

        <%= scope(:form_field, key: :home_assistant_normalize_urls, errors:).render do %>
          <%= form.check_box :home_assistant_normalize_urls,
                             id: :extension_home_assistant_normalize_urls,
                             checked: field_for(:home_assistant_normalize_urls, fields, extension),
                             switch: true,
                             class: :checkbox %>
          <label class="key" for="extension_home_assistant_normalize_urls">Normalize URLs</label>
        <% end %>

        <%= scope(:form_field, key: :home_assistant_attribute_map, errors:).render do %>
          <label class="key" for="extension_home_assistant_attribute_map">Attribute Map JSON</label>
          <%= form.text_area :home_assistant_attribute_map,
                             field_for(:home_assistant_attribute_map, fields, extension),
                             id: :extension_home_assistant_attribute_map,
                             class: "bit-editor",
                             autocomplete: :off,
                             "x-ref" => "homeAssistantAttributeMap",
                             data: {language: :json} %>
          <p class="help">
            Optional aliases for cleaner Liquid. Example:
            <code>{"aliases":{"roam":"media_player.sonos_roam","office":"media_player.office"}}</code>
          </p>
          <p class="help">
            Then use <code>{{ ha.roam.attributes.media_title }}</code> or
            <code>{{ home_assistant.aliases.roam.state }}</code>.
          </p>
        <% end %>

        <div class="bit-toggle-field">
          <h2 class="bit-toggle-label">Template Variable Reference</h2>
          <p class="help">Generated from selected entity IDs and aliases. Shows live current values for faster Liquid authoring.</p>
          <p class="help" x-show="entityDetailsLoading">Loading selected entity details...</p>
          <p class="help" x-show="entityDetailsError" x-text="entityDetailsError"></p>
          <p class="help" x-show="!entityDetailsLoading && selectedEntityDetails.length === 0">No selected entities yet.</p>

          <template x-for="entity in selectedEntityDetails" :key="entity.entity_id">
            <details style="margin: 8px 0; padding: 8px; border: 1px solid #ddd; border-radius: 8px;">
              <summary>
                <code x-text="aliasFor(entity.entity_id)"></code>
                <span> => </span>
                <code x-text="entity.entity_id"></code>
              </summary>
              <p class="help">
                Liquid: <code x-text="'{{ ha.' + aliasFor(entity.entity_id) + '.state }}'"></code>
              </p>
              <p class="help">
                Liquid: <code x-text="'{{ ha.' + aliasFor(entity.entity_id) + '.attributes.friendly_name }}'"></code>
              </p>
              <p class="help">Current state: <code x-text="entity.state"></code></p>

              <div style="max-height: 160px; overflow: auto; border: 1px solid #eee; border-radius: 6px; padding: 6px;">
                <template x-for="(value, key) in entity.attributes" :key="key">
                  <p class="help" style="margin: 4px 0;">
                    <code x-text="'ha.' + aliasFor(entity.entity_id) + '.attributes.' + key"></code>
                    <span> = </span>
                    <code x-text="typeof value === 'object' ? JSON.stringify(value) : String(value)"></code>
                  </p>
                </template>
              </div>
            </details>
          </template>
        </div>

        <div x-show="openEntityPicker"
             x-on:keydown.escape.window="openEntityPicker = false"
             style="position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:60;">
          <div style="background:#fff; width:min(1320px, 98vw); max-height:86vh; overflow:hidden; border-radius:10px; padding:16px; box-sizing:border-box;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
              <h3 style="margin:0; font-size:22px;">Home Assistant Entities</h3>
              <button type="button" class="bit-button-decline" x-on:click="openEntityPicker = false">Close</button>
            </div>

            <div style="display:flex; gap:10px; margin-bottom:12px;">
              <input type="text"
                     class="value"
                     style="flex:1 1 auto;"
                     placeholder="Filter by entity id, name, or state"
                     x-model="entityQuery"
                     x-on:input.debounce.300ms="searchEntities()"
                     x-on:keydown.enter.prevent>
            </div>

            <p x-show="entityLoading" class="help">Loading entities...</p>
            <p x-show="entityError" class="help" x-text="entityError"></p>

            <div style="max-height:62vh; overflow:auto; border:1px solid #ddd; border-radius:8px;">
              <table style="width:100%; border-collapse:collapse;">
                <thead>
                  <tr style="position:sticky; top:0; background:#fafafa;">
                    <th style="text-align:left; padding:6px; font-size:13px;">Entity</th>
                    <th style="text-align:left; padding:6px; font-size:13px;">Name</th>
                    <th style="text-align:left; padding:6px; font-size:13px;">State</th>
                    <th style="text-align:left; padding:6px; font-size:13px;">Domain</th>
                    <th style="text-align:right; padding:6px; font-size:13px;">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <template x-for="entity in entityResults" :key="entity.entity_id">
                    <tr>
                      <td style="padding:6px; border-top:1px solid #eee; font-size:13px;">
                        <code style="font-size:11px; line-height:1.2;" x-text="entity.entity_id"></code>
                      </td>
                      <td style="padding:6px; border-top:1px solid #eee; font-size:13px;" x-text="entity.friendly_name || '-'"></td>
                      <td style="padding:6px; border-top:1px solid #eee; font-size:13px;" x-text="entity.state"></td>
                      <td style="padding:6px; border-top:1px solid #eee; font-size:13px;" x-text="entity.domain"></td>
                      <td style="padding:6px; border-top:1px solid #eee; text-align:right;">
                        <button type="button" class="bit-button-accept" x-on:click="addEntity(entity); openEntityPicker = false">Add</button>
                      </td>
                    </tr>
                  </template>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <%= scope(
            :form_field,
            key: :body,
            errors:,
            alpine: {show: "kind === 'static'"}
          ).render do %>

        <label class="key" for="extension_body">
          Body
          <%= render "shared/popovers/triggers/default", name: :body %>
        </label>

        <%= form.text_area :body,
                           field_for(:formatted_body, fields, extension),
                           id: :extension_body,
                           class: "bit-editor",
                           autocomplete: :off,
                           data: {language: :json} %>
      <% end %>
    </fieldset>

    <%= tag.fieldset class: :column, "x-data" => "{unit: '#{field_for :unit, fields, extension}'}" do %>
      <legend class="legend">Schedule</legend>

      <%= scope(:form_field, key: :start_at, errors:).render do %>
        <label class="key" for="extension_start_at">
          Start
          <%= render "shared/popovers/triggers/default", name: :schedule_start %>
        </label>

        <%= form.datetime_local_field :start_at,
                                      id: :extension_start_at,
                                      value: field_for(:start_at, fields, extension),
                                      class: :value %>
      <% end %>

      <%= scope(:form_field, key: :interval, errors:).render do %>
        <label class="key" for="extension_interval">
          Interval
          <%= render "shared/popovers/triggers/default", name: :schedule_interval %>
        </label>

        <%= form.number_field :interval,
                              id: :extension_interval,
                              value: field_for(:interval, fields, extension),
                              min: 1,
                              class: :value %>
      <% end %>

      <%= scope(:form_field, key: :unit, errors:).render do %>
        <label class="key" for="extension_unit">
          Unit
          <%= render "shared/popovers/triggers/default", name: :schedule_unit %>
        </label>

        <% units = %w[none minute hour day week month] %>
        <% values = units.each.with_object({}) { |item, all| all[item.capitalize] = item } %>
        <%= form.select :unit, values, id: :extension_unit, class: :value, "x-model" => "unit" %>
      <% end %>

      <div class="bit-toggle-field" x-show="unit === 'week'">
        <h2 class="bit-toggle-label">
          Days
          <%= render "shared/popovers/triggers/default", name: :schedule_days %>
        </h2>

        <%= render "shared/checkboxes/bar",
                   items: [
                     %w[M monday],
                     %w[T tuesday],
                     %w[W wednesday],
                     %w[T thursday],
                     %w[F friday],
                     %w[S saturday],
                     %w[S sunday]
                   ],
                   collection: :extension,
                   key: :days,
                   attributes: fields,
                   record: extension %>
      </div>

      <%= scope(:form_field, key: :last_day_of_month, errors:, alpine: {show: "unit === 'month'"}).render do %>
        <%= form.check_box :last_day_of_month,
                           id: :extension_last_day_of_month,
                           checked: field_for(:last_day_of_month, fields, extension),
                           switch: true,
                           class: :checkbox %>

        <label class="key" for="extension_last_day_of_month">
          Last Day Of Month
          <%= render "shared/popovers/triggers/default", name: :last_day_of_month %>
        </label>
      <% end %>
    <% end %>
  </fieldset>

  <fieldset class="column" x-data="{matrix: 'models'}">
    <legend class="legend">Build Matrix</legend>
      <div class="bit-toggle-field">
        <%= render "shared/radios/bar",
                   items: [%w[Models models], %w[Devices devices]],
                   name: "matrix",
                   show: "matrix === 'models'",
                   model: "matrix" %>

        <p class="help" x-show="matrix === 'models'">
          Select the model(s) to render to.
        </p>

        <p class="help" x-show="matrix === 'devices'">
          Select the device(s) to render to.
          Best used when sensors are connected to your device.
          <em>Takes precedence over models.</em>
        </p>
      </div>

      <%= scope(:form_field, key: :models, errors:, alpine: {show: "matrix === 'models'"}).render do %>

        <label class="key" for="extension_models">
          Models
          <%= render "shared/popovers/triggers/default", name: :models %>
        </label>

        <select name="extension[model_ids][]"
                id="extension_models"
                multiple="multiple"
                class="value">
          <% selected_model_ids = extension ? extension.models.map(&:id) : [] %>
          <% models.each do |label, id| %>
            <%= tag.option label, value: id, selected: selected_model_ids.include?(id) %>
          <% end %>
        </select>
      <% end %>

      <%= scope(:form_field, key: :devices, errors:, alpine: {show: "matrix === 'devices'"}).render do %>

        <label class="key" for="extension_devices">
          Devices
          <%= render "shared/popovers/triggers/default", name: :devices %>
        </label>

        <select name="extension[device_ids][]"
                id="extension_devices"
                multiple="multiple"
                class="value">
          <% selected_device_ids = extension ? extension.devices.map(&:id) : [] %>
          <% devices.each do |label, id| %>
            <%= tag.option label, value: id, selected: selected_device_ids.include?(id) %>
          <% end %>
        </select>
      <% end %>
  </fieldset>
</fieldset>

<fieldset class="column" x-data="{input: 'source'}">
  <%= scope(:form_field, key: :template, errors:).render do %>
    <label class="key" for="extension_template">
      Template and Input
      <%= render "shared/popovers/triggers/default", name: :template %>
    </label>

    <%= form.text_area :template,
                       field_for(:template, fields, extension),
                       id: :extension_template,
                       class: "bit-editor",
                       autocomplete: :off,
                       data: {language: :liquid} %>
  <% end %>

  <div class="bit-toggle-field">
    <%= render "shared/radios/bar",
               items: [
                 %w[Source source],
                 %w[Sensors sensors],
                 %w[Fields fields],
                 %w[Data data]
               ],
               name: "input",
               show: "input === 'source'",
               model: "input" %>

    <details open x-show="input === 'source'">
      <summary>Usage</summary>

      <p>Provides read-only data sourced from your exchanges or Home Assistant source. This allows you to see all keys and values for use within your Liquid template.</p>

      <p>When supplying a single exchange, your Liquid template key will be <code>{{source_1}}</code>. Each subsequent exhange will be the next number in the sequence. Example: <code>{{source_1}}</code>, <code>{{source_2}}</code>, and so forth. Each key is numbered in the same order as your exchanges.</p>

      <p>For Home Assistant, use <code>{{source}}</code> for a single entity or endpoint response, <code>{{entities}}</code> for multiple entities, and <code>{{ha.alias_name}}</code> when aliases are configured.</p>

      <p>💡 In situations in where you have numeric keys, use brackets to reference the value. Example: <code>{"source_1": {"1": {"label": "Test"}}}</code>. This means you'd use <code>{{source_1["1"].label]}}</code> in your Liquid template to get the value.</p>
    </details>

    <details open x-show="input === 'sensors'">
      <summary>Usage</summary>

      <p>Provides read-only sensor data for use in your <a href="https://shopify.github.io/liquid/">Liquid</a> templates and is obtained as follows:</p>

      <ul>
        <li><strong>Device</strong>: Obtained from sensors connected to your ePaper device(s).</li>
        <li><strong>Server</strong>: Obtained from the sensors connected to the host that Terminus is running on. For example, a Raspberry Pi, using the <a href="https://github.com/usetrmnl/sensor_scanner">Sensor Scanner</a> project.</li>
      </ul>

      <p>To access sensor data within your Liquid template, use the top-level <code>{{sensors}}</code> key. This will be empty when no sensors are connected.</p>
    </details>

    <details open x-show="input === 'fields'">
      <summary>Usage</summary>

      <p>Provides editable data which allows you to supply custom form fields for use in your template. <em>Must be a JSON array of hashes</em>.</p>

      <p>These fields can be used in your Liquid template as follows:</p>

      <ul>
        <li><code>{{extension.fields}}</code>: Provides full access to all fields which means you can loop over all fields or pluck out a specific field by index. Example: <code>{{extension.fields[0].name}}</code>.</li>
        <li><code>{{extension.values}}</code>: Provides quick access to the default values (i.e. the value of the <code>default</code> key) of your fields. You can access thes values via the key's name (i.e. <code>keyname</code>). Example: <code>{{extension.values.demo}}</code>.</li>
      </ul>

      <p>💡 Check out our <a href="https://help.trmnl.com/en/articles/10513740-custom-plugin-form-builder">Help Center</a> documentation for further examples.</p>
    </details>

    <details open x-show="input === 'data'">
      <summary>Usage</summary>

      <p>Provides editable data for use in your <a href="https://shopify.github.io/liquid">Liquid</a> templates. All keys are wrapped within a top-level <code>extension</code> key. For example, let's assume you have the following content:</p>

      <p><code>{"label": "This is a demo!"}</code></p>

      <p>This means you can leverage the above in your Liquid template as <code>{{extension.data.label}}</code>.</p>

      <p>This includes field defaults when importing from the <%= link_to "Gallery", routes.path(:extensions_gallery) %> which will show up under a top-level <code>values</code> key. To override a field, use the <code>keyname</code> value as your key and any default or option as the value. Ensure you adhere to the <code>field_type</code> when adding a custom value. For example, let's say you have the following field (truncated for brevity):</p>

      <pre>
{
  "keyname": "temperature",
  "options": [
    {"Celsius": "celsius"},
    {"Fahrenheit": "fahrenheit"}
  ]
}</pre>

      <p>This means you could set your preference as follows: <code>{"values": {"temperature": "fahrenheit"}}</code>. In the future, this'll be configurable via form fields within the UI but, for now, you have to manually edit this data.</p>
    </details>
  </div>

  <% if extension %>
    <%= scope(:form_field, key: :response, errors:, alpine: {show: "input === 'source'"}).render do %>
      <%= tag.pre(
            **HTMX[
              get: routes.path(:extension_sources, extension_id: extension.id),
              trigger: :load,
              swap: "outerHTML"
            ]
          ) do %>Loading...<% end %>
    <% end %>

    <%= scope(:form_field, key: :sensors, errors:, alpine: {show: "input === 'sensors'"}).render do %>
      <%= tag.pre(
            **HTMX[
              get: routes.path(:extension_sensors, extension_id: extension.id),
              trigger: :load,
              swap: "outerHTML"
            ]
          ) do %>Loading...<% end %>
    <% end %>
  <% end %>

  <%= scope(:form_field, key: :data, errors:, alpine: {show: "input === 'data'"}).render do %>
    <%= form.text_area :data,
                       field_for(:formatted_data, fields, extension),
                       id: :extension_data,
                       class: "bit-editor",
                       autocomplete: :off,
                       data: {language: :json} %>
  <% end %>

  <%= scope(:form_field, key: :fields, errors:, alpine: {show: "input === 'fields'"}).render do %>
    <%= form.text_area :fields,
                       field_for(:formatted_fields, fields, extension),
                       id: :extension_fields,
                       class: "bit-editor",
                       autocomplete: :off,
                       data: {language: :json} %>
  <% end %>
</fieldset>

<%= render "extensions/shared/popovers/all" %>
