<%= render "shared/title", text: "New Model" %>

<section class="bit-page page-models">
  <header class="bit-header">
    <ul class="bit-breadcrumbs">
      <li class="bit-breadcrumb"><%= link_to "Models", routes.path(:models), class: :link %></li>
      <li class="bit-breadcrumb">New</li>
    </ul>
  </header>

  <div class="bit-body">
    <div class="models">
      <%= form_for :model, routes.path(:models), class: "bit-card bit-form model" do |form| %>
        <h1 class="label">New Model</h1>

        <%= render "models/shared/fields",
                   form:,
                   model:,
                   palette_options:,
                   fields:,
                   errors: %>

        <div class="form-actions">
          <%= render "shared/actions/save", form:, path: routes.path(:models) %>
          <%= link_to "Cancel", routes.path(:models), class: "bit-button-decline" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
